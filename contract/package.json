{
  "name": "@gendraw/contract",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Shared GenLayer contract ABI, types, and config for client and server",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./abi.json": "./src/abi.json",
    "./config": "./src/config.ts",
    "./types": "./src/types.ts",
    "./address": "./src/address.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  }
}
