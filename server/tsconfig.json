{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022"],
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "types": ["node", "vitest/globals"],
    "baseUrl": ".",
    "paths": {
      "@gendraw/contract": ["../contract/src/index.ts"],
      "@gendraw/contract/*": ["../contract/src/*"]
    }
  },
  "include": ["src", "vitest.config.ts"]
}
