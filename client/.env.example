# Copy this file to `.env.local` and fill in the values for local dev.
# When deploying to Vercel, set the same keys in the Vercel project's
# Environment Variables panel instead — Vite will inline them at build
# time.

# WalletConnect cloud project id (https://cloud.walletconnect.com/).
VITE_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id_here

# Public URL of the GenDraw Socket.IO relay.
#   - Local dev:    http://localhost:3001
#   - Production:   the Render Web Service URL (e.g. https://gendraw-server.onrender.com)
VITE_SOCKET_URL=http://localhost:3001
